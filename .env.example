# ==========================
# Application
# ==========================

APP_NAME=TalentFlow

# ==========================
# Database
# ==========================

DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/talentflow

# ==========================
# JWT
# ==========================

SECRET_KEY=your-secret-key
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================
# Uploads
# ==========================

UPLOAD_DIR=uploads

# ==========================
# Docker / PostgreSQL
# ==========================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=talentflow